    {
      "cell_type": "code",
      "source": [
        "from sklearn.cluster import KMeans\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.metrics import silhouette_score\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "print(\"--- GENERATING COMBINED MATHEMATICAL PROOF (ELBOW & SILHOUETTE) ---\")\n",
        "\n",
        "# 1. Isolate and scale features\n",
        "features = ['SPY_Daily_Return', 'SPY_Volatility_20d', 'CPI']\n",
        "X = df_cleaned[features].dropna()\n",
        "scaler = StandardScaler()\n",
        "X_scaled = scaler.fit_transform(X)\n",
        "\n",
        "# 2. Calculate metrics\n",
        "inertia = []\n",
        "silhouette_scores = []\n",
        "\n",
        "# Calculate Inertia for k=1 to 10\n",
        "K_range_inertia = range(1, 11)\n",
        "for k in K_range_inertia:\n",
        "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
        "    kmeans.fit(X_scaled)\n",
        "    inertia.append(kmeans.inertia_)\n",
        "\n",
        "# Calculate Silhouette for k=2 to 10 (Silhouette requires at least 2 clusters)\n",
        "K_range_sil = range(2, 11)\n",
        "for k in K_range_sil:\n",
        "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
        "    labels = kmeans.fit_predict(X_scaled)\n",
        "    score = silhouette_score(X_scaled, labels)\n",
        "    silhouette_scores.append(score)\n",
        "\n",
        "# 3. Plotting side-by-side\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))\n",
        "fig.suptitle('K-Means Optimization: Hyperparameter Selection for Sector Rotation', fontsize=16, fontweight='bold')\n",
        "\n",
        "# Panel 1: Elbow Method (Inertia)\n",
        "ax1.plot(K_range_inertia, inertia, marker='o', linestyle='--', color='blue', linewidth=2, markersize=8)\n",
        "ax1.set_title('Elbow Method (Inertia)', fontsize=14)\n",
        "ax1.set_xlabel('Number of Clusters (k)', fontsize=12)\n",
        "ax1.set_ylabel('Within-Cluster Sum of Squares', fontsize=12)\n",
        "ax1.axvline(x=3, color='red', linestyle='-', alpha=0.5, label='Selected k=3')\n",
        "ax1.legend()\n",
        "ax1.grid(alpha=0.3)\n",
        "\n",
        "# Panel 2: Silhouette Score\n",
        "ax2.plot(K_range_sil, silhouette_scores, marker='s', linestyle='-', color='green', linewidth=2, markersize=8)\n",
        "ax2.set_title('Silhouette Coefficient', fontsize=14)\n",
        "ax2.set_xlabel('Number of Clusters (k)', fontsize=12)\n",
        "ax2.set_ylabel('Silhouette Score (Closer to 1 is better)', fontsize=12)\n",
        "ax2.axvline(x=3, color='red', linestyle='--', alpha=0.5, label='Selected k=3')\n",
        "ax2.legend()\n",
        "ax2.grid(alpha=0.3)\n",
        "\n",
        "# Adjust layout and render\n",
        "plt.tight_layout()\n",
        "fig.subplots_adjust(top=0.88)\n",
        "plt.show()"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "--- GENERATING COMBINED MATHEMATICAL PROOF (ELBOW & SILHOUETTE) ---\n"
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": "<Figure size 1600x600 with 2 Axes>",
            "image/png": ""
