    {
      "cell_type": "markdown",
      "source": [
        "## Clustering Decision Making"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.cluster import KMeans\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "print(\"--- GENERATING MATHEMATICAL PROOF FOR K-MEANS (ELBOW METHOD) ---\")\n",
        "\n",
        "# 1. Isolate the exact features we used for clustering\n",
        "features = ['SPY_Daily_Return', 'SPY_Volatility_20d', 'CPI']\n",
        "X = df_cleaned[features].dropna()\n",
        "\n",
        "# 2. Scale the data (Required for accurate distance metrics)\n",
        "scaler = StandardScaler()\n",
        "X_scaled = scaler.fit_transform(X)\n",
        "\n",
        "# 3. Calculate Inertia for k=1 through k=10\n",
        "inertia = []\n",
        "K_range = range(1, 11)\n",
        "for k in K_range:\n",
        "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
        "    kmeans.fit(X_scaled)\n",
        "    inertia.append(kmeans.inertia_)\n",
        "\n",
        "# 4. Plot the Elbow Curve\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(K_range, inertia, marker='o', linestyle='--', color='b', linewidth=2, markersize=8)\n",
        "plt.title('K-Means Optimization: The Elbow Method', fontsize=14, fontweight='bold')\n",
        "plt.xlabel('Number of Clusters (k)', fontsize=12)\n",
        "plt.ylabel('Inertia (Within-Cluster Sum of Squares)', fontsize=12)\n",
        "\n",
        "# Highlight our chosen K=3\n",
        "plt.axvline(x=3, color='red', linestyle='-', alpha=0.5, label='Optimal k=3 (The Elbow)')\n",
        "plt.legend()\n",
        "plt.grid(alpha=0.3)\n",
        "plt.show()"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "--- GENERATING MATHEMATICAL PROOF FOR K-MEANS (ELBOW METHOD) ---\n"
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": "<Figure size 1000x600 with 1 Axes>",
            "image/png": ""
          },
          "metadata": {}
        }
      ],
      "execution_count": 11,
      "metadata": {
        "gather": {
          "logged": 1775054913948
        }
      }
