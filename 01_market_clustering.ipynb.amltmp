    {
      "cell_type": "markdown",
      "source": [
        "## Generating SILHOUETTE SCORE"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.metrics import silhouette_score\n",
        "\n",
        "print(\"--- GENERATING MATHEMATICAL PROOF 2: SILHOUETTE SCORE ---\")\n",
        "\n",
        "# We use the same scaled data (X_scaled) from the Elbow Method cell\n",
        "silhouette_scores = []\n",
        "\n",
        "# Silhouette requires at least 2 clusters to compare distance, so we start at k=2\n",
        "K_range_sil = range(2, 11)\n",
        "\n",
        "for k in K_range_sil:\n",
        "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
        "    labels = kmeans.fit_predict(X_scaled)\n",
        "    score = silhouette_score(X_scaled, labels)\n",
        "    silhouette_scores.append(score)\n",
        "\n",
        "# Plot the Silhouette Curve\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(K_range_sil, silhouette_scores, marker='s', linestyle='-', color='green', linewidth=2, markersize=8)\n",
        "plt.title('K-Means Optimization: Silhouette Coefficient', fontsize=14, fontweight='bold')\n",
        "plt.xlabel('Number of Clusters (k)', fontsize=12)\n",
        "plt.ylabel('Silhouette Score (Closer to 1 is better)', fontsize=12)\n",
        "\n",
        "# Highlight our chosen K=3\n",
        "plt.axvline(x=3, color='red', linestyle='--', alpha=0.5, label='Selected Model: k=3')\n",
        "plt.legend()\n",
        "plt.grid(alpha=0.3)\n",
        "plt.show()"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "--- GENERATING MATHEMATICAL PROOF 2: SILHOUETTE SCORE ---\n"
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": "<Figure size 1000x600 with 1 Axes>",
            "image/png": ""
          },
          "metadata": {}
        }
      ],
      "execution_count": 12,
